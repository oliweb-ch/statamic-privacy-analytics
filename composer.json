{
    "name": "oliweb/statamic-privacy-analytics",
    "description": "A powerful, efficient analytics solution for Statamic with real-time tracking, caching, and comprehensive dashboard visualization.",
    "type": "statamic-addon",
    "keywords": [
        "statamic",
        "statamic-addon",
        "analytics",
        "statamic-analytics",
        "enhanced",
        "real-time",
        "tracking",
        "cache",
        "performance",
        "dashboard",
        "chart",
        "chartjs",
        "alpinejs"
    ],
    "autoload": {
        "psr-4": {
            "Oliweb\\StatamicAnalytics\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Oliweb\\StatamicAnalytics\\Tests\\": "tests"
        }
    },
    "extra": {
        "statamic": {
            "name": "Privacy Analytics",
            "description": "A powerful, efficient analytics solution for Statamic with real-time tracking and comprehensive dashboard"
        },
        "laravel": {
            "providers": [
                "Oliweb\\StatamicAnalytics\\ServiceProvider"
            ]
        }
    },
    "require": {
        "php": "^8.3",
        "statamic/cms": "^6.0",
        "jenssegers/agent": "^2.6"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0"
    },
    "config": {
        "allow-plugins": {
            "pixelfear/composer-dist-plugin": true
        }
    }
}
